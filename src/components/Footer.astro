---
import { COMPANY } from '../lib/constants';
import { useTranslations } from '../i18n';

const locale = Astro.url.pathname.startsWith('/zh/') ? 'zh' : 'en';
const t = useTranslations(locale);
const localizedPath = (path: string) => locale === 'zh' ? `/zh${path}` : path;
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {/* Company Info */}
      <div class="sm:col-span-2 lg:col-span-1">
        <img src="/images/logo-white.png" alt={COMPANY.shortNameEn} class="h-16 w-auto mb-4" />
        <p class="text-sm text-gray-300 leading-relaxed mb-4">
          {locale === 'zh'
            ? '专注食品工厂自动供料系统的研发、设计与制造'
            : 'Specialized in R&D, design and manufacturing of automatic food feeding systems'}
        </p>
        <p class="text-sm text-gray-300">
          {locale === 'zh' ? '地址：' : 'Add: '}{locale === 'zh' ? COMPANY.address : COMPANY.addressEn}
        </p>
      </div>

      {/* Quick Links */}
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-4">{locale === 'zh' ? '快速链接' : 'Quick Links'}</h4>
        <ul class="space-y-2.5">
          <li><a href={localizedPath('/products/')} class="text-sm text-gray-300 hover:text-white transition-colors">{t.footer.products}</a></li>
          <li><a href={localizedPath('/solutions/')} class="text-sm text-gray-300 hover:text-white transition-colors">{t.footer.solutions}</a></li>
          <li><a href={localizedPath('/about/')} class="text-sm text-gray-300 hover:text-white transition-colors">{t.footer.about}</a></li>
          <li><a href={localizedPath('/contact/')} class="text-sm text-gray-300 hover:text-white transition-colors">{t.footer.contact}</a></li>
        </ul>
      </div>

      {/* Products */}
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-4">{t.footer.products}</h4>
        <ul class="space-y-2.5">
          <li><a href={localizedPath('/products/')} class="text-sm text-gray-300 hover:text-white transition-colors">{locale === 'zh' ? '成型设备' : 'Forming Machines'}</a></li>
          <li><a href={localizedPath('/solutions/filling-system')} class="text-sm text-gray-300 hover:text-white transition-colors">{locale === 'zh' ? '自动供料系统' : 'Auto Feeding Systems'}</a></li>
          <li><a href={localizedPath('/solutions/cleaning')} class="text-sm text-gray-300 hover:text-white transition-colors">{locale === 'zh' ? '清洗系统' : 'Cleaning Systems'}</a></li>
          <li><a href={localizedPath('/products/')} class="text-sm text-gray-300 hover:text-white transition-colors">CNC {locale === 'zh' ? '精密加工' : 'Precision Machining'}</a></li>
        </ul>
      </div>

      {/* Contact */}
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-4">{t.footer.contact}</h4>
        <ul class="space-y-2.5 text-sm text-gray-300">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span>{COMPANY.phone}</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span>{COMPANY.email}</span>
          </li>
          <li>
            <a href={`https://wa.me/${COMPANY.whatsapp}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 hover:text-white transition-colors">
              <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <span>WhatsApp</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="mt-10 pt-6 border-t border-primary-light/30">
      <p class="text-xs text-gray-400 text-center">
        {locale === 'zh' ? COMPANY.name : COMPANY.nameEn} &mdash; {t.footer.rights}
      </p>
    </div>
  </div>
</footer>
