---
export interface Props {
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { title, description, align = 'center' } = Astro.props;
---

<div class="mb-10 lg:mb-14" class:list={{ 'text-center': align === 'center', 'text-left': align === 'left' }}>
  <h2 class="text-3xl lg:text-4xl font-bold text-primary mb-4">{title}</h2>
  {description && (
    <p class="text-lg text-text-muted max-w-2xl mx-auto" class:list={{ 'mx-auto': align === 'center', 'mx-0': align === 'left' }}>
      {description}
    </p>
  )}
</div>
