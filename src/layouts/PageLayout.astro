---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  locale: string;
  alternateHref?: string;
  alternateLocale?: string;
  breadcrumb?: { label: string; href?: string }[];
}

const { title, description, locale, alternateHref, alternateLocale, breadcrumb } = Astro.props;
---

<BaseLayout {title} {description} {locale} {alternateHref} {alternateLocale}>
  {breadcrumb && breadcrumb.length > 0 && (
    <nav class="bg-bg-alt border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-sm text-text-muted">
        <a href={locale === 'zh' ? '/zh/' : '/'} class="hover:text-primary transition-colors">{locale === 'zh' ? '首页' : 'Home'}</a>
        {breadcrumb.map((crumb, i) => (
          <span>
            <span class="mx-2">/</span>
            {crumb.href ? (
              <a href={crumb.href} class="hover:text-primary transition-colors">{crumb.label}</a>
            ) : (
              <span class="text-primary font-medium">{crumb.label}</span>
            )}
          </span>
        ))}
      </div>
    </nav>
  )}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <slot />
  </div>
</BaseLayout>
