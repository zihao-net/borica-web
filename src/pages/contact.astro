---
import PageLayout from '../layouts/PageLayout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { useTranslations } from '../i18n';
import { COMPANY } from '../lib/constants';

const locale = 'en';
const t = useTranslations(locale);
---

<PageLayout
  title={t.contact.title}
  description={t.contact.desc}
  locale={locale}
  breadcrumb={[{ label: t.contact.title }]}
>
  <h1 class="text-3xl lg:text-4xl font-bold text-primary mb-4">{t.contact.title}</h1>
  <p class="text-lg text-text-muted mb-10">{t.contact.desc}</p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
    <div>
      <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="bg-white rounded-xl border border-border p-6 lg:p-8">
        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
        <input type="hidden" name="subject" value="Borica Website Inquiry" />
        <input type="hidden" name="from_name" value="Borica Website" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium text-primary mb-1.5">{t.contact.form.name} *</label>
            <input type="text" name="name" required class="w-full px-4 py-2.5 border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-primary mb-1.5">{t.contact.form.company}</label>
            <input type="text" name="company" class="w-full px-4 py-2.5 border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-sm font-medium text-primary mb-1.5">{t.contact.form.email} *</label>
            <input type="email" name="email" required class="w-full px-4 py-2.5 border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" />
          </div>
          <div>
            <label class="block text-sm font-medium text-primary mb-1.5">{t.contact.form.phone} *</label>
            <input type="text" name="phone" required class="w-full px-4 py-2.5 border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors" />
          </div>
        </div>

        <div class="mb-4">
          <label class="block text-sm font-medium text-primary mb-1.5">{t.contact.form.product}</label>
          <select name="product" class="w-full px-4 py-2.5 border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors bg-white">
            <option value="">{t.contact.form.placeholder}</option>
            <option value="Solid Forming Machine (BRK-SC08)">Solid Forming Machine BRK-SC08</option>
            <option value="Stuffed Forming Machine (BRK-BC08)">Stuffed Forming Machine BRK-BC08</option>
            <option value="Large Forming Machine (BRK-SC05)">Large Forming Machine BRK-SC05</option>
            <option value="Patty Forming Machine (BRK-YP6)">Patty Forming Machine BRK-YP6</option>
            <option value="Auto Filling System">Auto Filling System</option>
            <option value="Auto Dough Feeding System">Auto Dough Feeding System</option>
            <option value="Cleaning System">Cleaning System</option>
            <option value="Automation Line">Automation Line</option>
            <option value="CNC Machining">CNC Machining</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="mb-6">
          <label class="block text-sm font-medium text-primary mb-1.5">{t.contact.form.message} *</label>
          <textarea name="message" rows="4" required class="w-full px-4 py-2.5 border border-border rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors resize-y"></textarea>
        </div>

        <button type="submit" class="w-full px-6 py-3 bg-primary hover:bg-primary-light text-white font-semibold rounded-lg transition-colors">
          {t.contact.form.submit}
        </button>
        <p id="form-success" class="hidden mt-4 text-sm text-green-600 font-medium text-center">{t.contact.form.success}</p>
      </form>
    </div>

    <div>
      <div class="bg-white rounded-xl border border-border p-6 lg:p-8 mb-6">
        <h2 class="text-xl font-bold text-primary mb-6">{t.contact.info}</h2>
        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p class="font-medium text-primary">Phone</p>
              <a href={`tel:${COMPANY.phone}`} class="text-text-muted hover:text-primary transition-colors">{COMPANY.phone}</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="font-medium text-primary">Email</p>
              <a href={`mailto:${COMPANY.email}`} class="text-text-muted hover:text-primary transition-colors">{COMPANY.email}</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            <div>
              <p class="font-medium text-primary">WhatsApp</p>
              <a href={`https://wa.me/${COMPANY.whatsapp}`} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary transition-colors">Click to chat directly</a>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <p class="font-medium text-primary">Address</p>
              <p class="text-text-muted text-sm">{COMPANY.addressEn}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <WhatsAppButton />
</PageLayout>
