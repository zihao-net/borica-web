---
import PageLayout from '../../layouts/PageLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { useTranslations } from '../../i18n';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  const enProducts = products.filter((p) => p.id.startsWith('en/') && p.data.published);
  return enProducts.map((p) => ({
    params: { slug: p.id.replace('en/', '').replace('.md', '') },
    props: { product: p },
  }));
}

const locale = 'en';
const t = useTranslations(locale);
const { product } = Astro.props;
const { data } = product;
const { Content } = await product.render();
---

<PageLayout
  title={data.title}
  description={data.model ? `${data.model} - ${data.title}` : data.title}
  locale={locale}
  breadcrumb={[
    { label: t.products.title, href: `/products/` },
    { label: data.title },
  ]}
>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mb-12">
    <div>
      <div class="aspect-[4/3] bg-bg-alt rounded-xl flex items-center justify-center">
        {data.heroImage ? (
          <img src={data.heroImage} alt={data.title} class="w-full h-full object-cover rounded-xl" />
        ) : (
          <div class="text-text-muted text-center p-8">
            <svg class="w-20 h-20 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <span class="text-sm">Product Image</span>
          </div>
        )}
      </div>
    </div>

    <div>
      {data.model && (
        <span class="text-sm font-mono text-accent font-semibold uppercase tracking-wider">{data.model}</span>
      )}
      <h1 class="text-3xl lg:text-4xl font-bold text-primary mt-2 mb-6">{data.title}</h1>

      {data.features && data.features.length > 0 && (
        <div class="mb-8">
          <h3 class="text-lg font-semibold text-primary mb-3">{t.products.features}</h3>
          <ul class="space-y-2.5">
            {data.features.map((f) => (
              <li class="flex items-start gap-2 text-text-muted">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <a
        href={`/contact/`}
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-light text-white font-semibold rounded-lg transition-colors"
      >
        {t.products.inquiry}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>

  {data.specs && data.specs.length > 0 && (
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-primary mb-6">{t.products.specs}</h2>
      <div class="bg-white rounded-xl border border-border overflow-hidden">
        {data.specs.map((spec, i) => (
          <div class="flex border-b border-border last:border-0" class:list={{ 'bg-bg-alt': i % 2 === 1 }}>
            <div class="w-1/3 px-5 py-3.5 text-sm font-medium text-text-muted">{spec.label}</div>
            <div class="w-2/3 px-5 py-3.5 text-sm text-[#1a1a1a]">{spec.value}</div>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="prose prose-gray max-w-none mb-12">
    <Content />
  </div>

  <CTABanner />
  <WhatsAppButton />
</PageLayout>
