---
import PageLayout from '../../layouts/PageLayout.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { useTranslations } from '../../i18n';
import { COMPANY } from '../../lib/constants';

const locale = 'zh';
const t = useTranslations(locale);
---

<PageLayout
  title={t.service.title}
  description={t.service.desc}
  locale={locale}
  breadcrumb={[{ label: t.service.title }]}
>
  <h1 class="text-3xl lg:text-4xl font-bold text-primary mb-4">{t.service.title}</h1>
  <p class="text-lg text-text-muted mb-10">{t.service.desc}</p>

  {/* Full Lifecycle Flow */}
  <div class="mb-12">
    <h2 class="text-2xl font-bold text-primary mb-6">{t.service['流程']}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {t.service.steps.map((step, i) => (
        <div class="bg-white rounded-xl border border-border p-6 relative">
          <span class="absolute top-4 right-4 text-3xl font-bold text-primary/10">{String(i + 1).padStart(2, '0')}</span>
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h3 class="font-semibold text-primary mb-2">{step.title}</h3>
          <p class="text-sm text-text-muted">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>

  {/* Warranty */}
  <div class="bg-bg-alt rounded-xl p-8 lg:p-10 mb-12">
    <h2 class="text-2xl font-bold text-primary mb-6">{t.service.warranty}</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
      {t.service.warrantyItems.map((item) => (
        <div class="text-center">
          <div class="text-lg lg:text-xl font-bold text-accent mb-1">{item.value}</div>
          <div class="text-xs text-text-muted">{item.label}</div>
        </div>
      ))}
    </div>
  </div>

  {/* After-sales Commitment */}
  <div class="bg-white rounded-xl border border-border p-8 lg:p-10">
    <h2 class="text-2xl font-bold text-primary mb-6">{locale === 'zh' ? '售后服务体系' : 'After-Sales Service'}</h2>
    <div class="space-y-4">
      <div class="flex items-start gap-4">
        <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-primary mb-1">{locale === 'zh' ? '质保期 ≥ 1年' : 'Warranty ≥ 1 year'}</h3>
          <p class="text-sm text-text-muted">{locale === 'zh' ? '质保期内非人为因素无偿维修更换' : 'Free repair and replacement for non-human factors during warranty'}</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-primary mb-1">{locale === 'zh' ? '2小时内响应' : 'Response within 2 hours'}</h3>
          <p class="text-sm text-text-muted">{locale === 'zh' ? '接到报障通知2小时内作出响应' : 'Response within 2 hours of fault notification'}</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-primary mb-1">{locale === 'zh' ? '24小时到场' : 'On-site within 24 hours'}</h3>
          <p class="text-sm text-text-muted">{locale === 'zh' ? '紧急故障24小时内工程师到达现场' : 'Engineer on-site within 24 hours for emergencies'}</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        </div>
        <div>
          <h3 class="font-semibold text-primary mb-1">{locale === 'zh' ? '备件和技术培训' : 'Spare Parts & Training'}</h3>
          <p class="text-sm text-text-muted">{locale === 'zh' ? '随机配备1%-3%备品备件，免费操作培训+维保培训' : '1%-3% spare parts included, free operation & maintenance training'}</p>
        </div>
      </div>
    </div>
  </div>

  <WhatsAppButton />
</PageLayout>
